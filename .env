# ==================== EASYPARK - Variables Globales ====================

# ==================== BASE DE DATOS ====================
# MySQL - Credenciales
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_HOST=dbUser
MYSQL_PORT=3306

# USER Service Database
MYSQL_DATABASE=easypark_db
MYSQL_USER=easypark_user
MYSQL_PASSWORD=easypark_pass123

# PARKING Service Database
PARKING_DB_NAME=parking_db
PARKING_DB_USER=parking_user
PARKING_DB_PASSWORD=parking_pass123

# RESERVATION Service Database
RESERVATION_DB_NAME=reservation_db
RESERVATION_DB_USER=reservation_user
RESERVATION_DB_PASSWORD=reservation_pass123

# ==================== BACKEND (Spring Boot) ====================
SERVER_PORT_USER=8080
SERVER_PORT_PARKING=8081
SERVER_PORT_RESERVATION=8082
EUREKA_PORT=8761
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Eureka
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://eureka:8761/eureka/
EUREKA_INSTANCE_PREFER_IP_ADDRESS=true

# ==================== FRONTEND (React) ====================
REACT_APP_API_URL=http://localhost:8080
OWNER_APP_PORT=3000
ADMIN_APP_PORT=3001

# ==================== AMBIENTE ====================
NODE_ENV=development
ENVIRONMENT=development

